<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.example.dsafinals.controllers.JournalController"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      spacing="10.0" style="-fx-background-color: -bg-color; -fx-padding: 20;"
      stylesheets="@../stylesheets/application.css">
    <children>
        <HBox spacing="8.0">
            <children>
                <TextField fx:id="searchField" promptText="Search by date (yyyy-MM-dd)" HBox.hgrow="ALWAYS"/>
                <Button text="Search" styleClass="toolbar-button" onAction="#handleSearch"/>
                <Button text="Sort by Date" styleClass="toolbar-button" onAction="#handleSortByDate"/>
                <Button text="Sort by Title" styleClass="toolbar-button" onAction="#handleSortByTitle"/>
            </children>
        </HBox>
        <Label fx:id="resultLabel" styleClass="muted-text"/>
        <ListView fx:id="entryListView" VBox.vgrow="ALWAYS"/>
    </children>
</VBox>
