<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<!-- Root: two permanent panes side by side, Day One-style -->
<HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      style="-fx-background-color: -bg-color;"
      stylesheets="@../stylesheets/application.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dsafinals.controllers.JournalController">
    <children>

        <!-- ══════════════════════════════════════
             LEFT: entry list, grouped by month
             ══════════════════════════════════════ -->
        <VBox minWidth="280.0" prefWidth="320.0" maxWidth="360.0"
              style="-fx-background-color: #171717; -fx-border-width: 0 1 0 0; -fx-border-color: #262626;">
            <children>

                <VBox spacing="12.0">
                    <padding><Insets top="20.0" left="18.0" right="18.0" bottom="12.0"/></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Text styleClass="title-text" text="Journal">
                                    <font><Font size="22.0"/></font>
                                </Text>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="newEntryButton" mnemonicParsing="false"
                                        styleClass="primary-button"
                                        stylesheets="@../stylesheets/buttons.css"
                                        text="+ New">
                                    <padding><Insets top="6.0" bottom="6.0" left="12.0" right="12.0"/></padding>
                                </Button>
                            </children>
                        </HBox>

                        <TextField fx:id="searchField"
                                   promptText="Search entries…"
                                   style="-fx-background-color: #1e1e1e;
                                          -fx-text-fill: white;
                                          -fx-prompt-text-fill: #555;
                                          -fx-border-color: #333;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 7 10;"/>
                    </children>
                </VBox>

                <ScrollPane fx:id="listScrollPane" fitToWidth="true" focusTraversable="false"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <VBox style="-fx-background-color: transparent;">
                            <children>

                                <!-- Empty state -->
                                <StackPane fx:id="emptyState" managed="false" visible="false" prefHeight="180.0">
                                    <children>
                                        <VBox alignment="CENTER" spacing="8.0">
                                            <children>
                                                <Text styleClass="muted-text" text="No journal entries yet."/>
                                                <Text styleClass="muted-text" text="Tap &quot;+ New&quot; to write your first one."
                                                      wrappingWidth="220.0" textAlignment="CENTER"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </StackPane>

                                <!-- Month groups + entry rows injected here -->
                                <VBox fx:id="groupedListContainer" spacing="4.0">
                                    <padding><Insets bottom="20.0"/></padding>
                                </VBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </VBox>

        <!-- ══════════════════════════════════════
             RIGHT: detail / editor pane
             ══════════════════════════════════════ -->
        <StackPane HBox.hgrow="ALWAYS">
            <children>

                <!-- Nothing selected -->
                <VBox fx:id="detailEmptyState" alignment="CENTER" spacing="8.0">
                    <children>
                        <Text styleClass="muted-text" text="Select an entry to read it"
                              style="-fx-font-size: 16px;"/>
                        <Text styleClass="muted-text" text="or start a new one from the left panel."/>
                    </children>
                </VBox>

                <ScrollPane fx:id="editorScrollPane" fitToWidth="true" focusTraversable="false"
                            managed="false" visible="false"
                            style="-fx-background-color: -bg-color; -fx-background: -bg-color;">
                    <content>
                        <VBox spacing="18.0" maxWidth="760.0">
                            <padding><Insets top="30.0" left="50.0" right="50.0" bottom="40.0"/></padding>
                            <children>

                                <!-- Top bar: date/time + actions -->
                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                    <children>
                                        <Text fx:id="dateTimeText" styleClass="muted-text"
                                              text="Wednesday, Apr 2, 2025 at 12:23 PM">
                                            <font><Font size="13.0"/></font>
                                        </Text>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="deleteButton" mnemonicParsing="false"
                                                styleClass="transparent-button"
                                                stylesheets="@../stylesheets/buttons.css"
                                                text="Delete"
                                                style="-fx-text-fill: #ef4444; -fx-background-color: transparent;"/>
                                        <Button fx:id="saveButton" mnemonicParsing="false"
                                                styleClass="primary-button"
                                                stylesheets="@../stylesheets/buttons.css"
                                                text="Save">
                                            <padding><Insets top="8.0" bottom="8.0" left="16.0" right="16.0"/></padding>
                                        </Button>
                                    </children>
                                </HBox>

                                <!-- Title -->
                                <TextField fx:id="titleField"
                                           promptText="Entry title…"
                                           style="-fx-font-size: 28px;
                                                  -fx-font-weight: bold;
                                                  -fx-background-color: transparent;
                                                  -fx-text-fill: white;
                                                  -fx-prompt-text-fill: #444;
                                                  -fx-border-width: 0 0 1 0;
                                                  -fx-border-color: #262626;
                                                  -fx-padding: 6 0;"/>

                                <!-- Date + Tags -->
                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                    <children>
                                        <Text styleClass="muted-text" text="Date"/>
                                        <DatePicker fx:id="datePicker"
                                                    style="-fx-background-color: #1e1e1e; -fx-text-fill: white;"
                                                    prefWidth="170.0"/>
                                        <TextField fx:id="tagInputField"
                                                   promptText="Add a tag and press Enter…"
                                                   HBox.hgrow="ALWAYS"
                                                   style="-fx-background-color: #1e1e1e;
                                                          -fx-text-fill: white;
                                                          -fx-prompt-text-fill: #555;
                                                          -fx-border-color: #333;
                                                          -fx-border-radius: 6;
                                                          -fx-background-radius: 6;"/>
                                    </children>
                                </HBox>
                                <FlowPane fx:id="tagsFlowPane" hgap="8.0" vgap="6.0"/>

                                <!-- Body text — reads like a page of the journal -->
                                <TextArea fx:id="contentArea"
                                          promptText="Write your thoughts…"
                                          wrapText="true"
                                          prefHeight="420.0"
                                          style="-fx-control-inner-background: -bg-color;
                                                 -fx-background-color: transparent;
                                                 -fx-text-fill: #e5e5e5;
                                                 -fx-prompt-text-fill: #555;
                                                 -fx-border-width: 0;
                                                 -fx-font-size: 16px;"/>

                                <!-- Photos -->
                                <VBox spacing="8.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <children>
                                                <Text styleClass="muted-text" text="Photos"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Button fx:id="addPhotoButton"
                                                        mnemonicParsing="false"
                                                        styleClass="sidebar-button"
                                                        stylesheets="@../stylesheets/buttons.css"
                                                        text="+ Attach Photo"
                                                        textFill="WHITE"/>
                                            </children>
                                        </HBox>
                                        <FlowPane fx:id="photosFlowPane" hgap="10.0" vgap="10.0"/>
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </StackPane>

    </children>
</HBox>
