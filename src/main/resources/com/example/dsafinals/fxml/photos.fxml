<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" fitToHeight="true" focusTraversable="false"
            style="-fx-background-color: -bg-color; -fx-background: -bg-color;"
            stylesheets="@../stylesheets/application.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dsafinals.controllers.PhotosController">
    <content>
        <VBox style="-fx-background-color: -bg-color; -fx-padding: 30;" spacing="16.0">
            <children>

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Text strokeType="OUTSIDE" strokeWidth="0.0"
                                      styleClass="title-text" text="Photos">
                                    <font><Font size="36.0"/></font>
                                </Text>
                                <Text fx:id="photoCountText" styleClass="muted-text" text="0 photos"/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="sortComboBox" prefWidth="190.0"/>
                    </children>
                </HBox>

                <!-- Filter bar -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <TextField fx:id="searchField"
                                   promptText="Search by name or caption…"
                                   prefWidth="220.0"
                                   style="-fx-background-color: #1e1e1e; -fx-text-fill: white;
                                          -fx-prompt-text-fill: #555; -fx-border-color: #333;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 8 12;"/>
                        <Text styleClass="muted-text" text="From"/>
                        <TextField fx:id="fromDateField"
                                   promptText="YYYY-MM-DD"
                                   prefWidth="130.0"
                                   style="-fx-background-color: #1e1e1e; -fx-text-fill: white;
                                          -fx-prompt-text-fill: #555; -fx-border-color: #333;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 8 12;"/>
                        <Text styleClass="muted-text" text="To"/>
                        <TextField fx:id="toDateField"
                                   promptText="YYYY-MM-DD"
                                   prefWidth="130.0"
                                   style="-fx-background-color: #1e1e1e; -fx-text-fill: white;
                                          -fx-prompt-text-fill: #555; -fx-border-color: #333;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 8 12;"/>
                        <Button fx:id="filterButton" mnemonicParsing="false"
                                styleClass="primary-button"
                                stylesheets="@../stylesheets/buttons.css"
                                text="Filter">
                            <padding>
                                <Insets bottom="8.0" left="14.0" right="14.0" top="8.0"/>
                            </padding>
                        </Button>
                        <Button fx:id="clearFilterButton" mnemonicParsing="false"
                                styleClass="sidebar-button"
                                stylesheets="@../stylesheets/buttons.css"
                                text="Clear" textFill="WHITE"/>
                    </children>
                </HBox>

                <!-- Photo grid -->
                <FlowPane fx:id="photoGrid" hgap="12.0" vgap="12.0"/>

                <!-- Empty state -->
                <StackPane fx:id="emptyState" managed="false" visible="false" prefHeight="200.0">
                    <children>
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Text styleClass="muted-text" text="No photos yet."
                                      style="-fx-font-size: 16px;"/>
                                <Text styleClass="muted-text"
                                      text="Import photos through the Albums page to see them here."/>
                            </children>
                        </VBox>
                    </children>
                </StackPane>

            </children>
        </VBox>
    </content>
</ScrollPane>
