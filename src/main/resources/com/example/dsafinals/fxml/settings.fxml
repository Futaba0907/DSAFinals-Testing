<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" fitToHeight="true" focusTraversable="false"
            style="-fx-background-color: -bg-color; -fx-background: -bg-color;"
            stylesheets="@../stylesheets/application.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dsafinals.controllers.SettingsController">
    <content>
        <VBox style="-fx-background-color: -bg-color; -fx-padding: 30;" spacing="28.0"
              maxWidth="720.0">
            <children>

                <!-- Page header -->
                <Text strokeType="OUTSIDE" strokeWidth="0.0"
                      styleClass="title-text" text="Settings">
                    <font><Font size="36.0"/></font>
                </Text>

                <!-- ── ABOUT ──────────────────────────────── -->
                <VBox spacing="14.0"
                      style="-fx-background-color: #1e1e1e; -fx-background-radius: 12; -fx-padding: 20;">
                    <children>
                        <Text styleClass="text"
                              style="-fx-font-size: 18px; -fx-font-weight: bold;"
                              text="About"/>
                        <Separator style="-fx-background-color: #333;"/>

                        <HBox spacing="12.0">
                            <children>
                                <Text styleClass="muted-text" text="App"
                                      style="-fx-min-width: 120px;"/>
                                <Text styleClass="text"
                                      text="Local Photo Archive &amp; Digital Journal"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0">
                            <children>
                                <Text styleClass="muted-text" text="Group"
                                      style="-fx-min-width: 120px;"/>
                                <Text styleClass="text" text="Capybara"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Proponents"
                                      style="-fx-min-width: 120px;"/>
                                <VBox spacing="4.0">
                                    <children>
                                        <Text styleClass="text" text="Brittanie Kate Basilio"/>
                                        <Text styleClass="text" text="Robert Angelo Bucala"/>
                                        <Text styleClass="text" text="Thomas Louis Hari"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <HBox spacing="12.0">
                            <children>
                                <Text styleClass="muted-text" text="Course"
                                      style="-fx-min-width: 120px;"/>
                                <Text styleClass="text" text="Data Structures and Algorithms"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Description"
                                      style="-fx-min-width: 120px;"/>
                                <Text styleClass="muted-text" wrappingWidth="480.0"
                                      text="An offline desktop application designed to help users store, organize, and revisit personal memories through journal entries and image collections. Operates entirely on local storage — no subscriptions or internet required."/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- ── STORAGE ────────────────────────────── -->
                <VBox spacing="14.0"
                      style="-fx-background-color: #1e1e1e; -fx-background-radius: 12; -fx-padding: 20;">
                    <children>
                        <Text styleClass="text"
                              style="-fx-font-size: 18px; -fx-font-weight: bold;"
                              text="Storage"/>
                        <Separator style="-fx-background-color: #333;"/>

                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Data folder"
                                      style="-fx-min-width: 120px;"/>
                                <Label fx:id="storagePathLabel"
                                       style="-fx-text-fill: #93a1a1; -fx-font-size: 13px;"
                                       wrapText="true" maxWidth="480.0"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0">
                            <children>
                                <Text styleClass="muted-text" text="Entries"
                                      style="-fx-min-width: 120px;"/>
                                <Label fx:id="entryCountLabel" styleClass="muted-text"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0">
                            <children>
                                <Text styleClass="muted-text" text="Photos"
                                      style="-fx-min-width: 120px;"/>
                                <Label fx:id="photoCountLabel" styleClass="muted-text"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- ── DATA MANAGEMENT ───────────────────── -->
                <VBox spacing="14.0"
                      style="-fx-background-color: #1e1e1e; -fx-background-radius: 12; -fx-padding: 20;">
                    <children>
                        <Text styleClass="text"
                              style="-fx-font-size: 18px; -fx-font-weight: bold;"
                              text="Data Management"/>
                        <Separator style="-fx-background-color: #333;"/>

                        <!-- Export -->
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Text styleClass="text" text="Export Journal Entries"/>
                                        <Text styleClass="muted-text"
                                              text="Save all entries as a readable .txt file to a folder of your choice."/>
                                    </children>
                                </VBox>
                                <Button fx:id="exportButton" mnemonicParsing="false"
                                        styleClass="primary-button"
                                        stylesheets="@../stylesheets/buttons.css"
                                        text="Export">
                                    <padding>
                                        <Insets bottom="10.0" left="17.0" right="17.0" top="10.0"/>
                                    </padding>
                                </Button>
                            </children>
                        </HBox>

                        <Separator style="-fx-background-color: #2a2a2a;"/>

                        <!-- Clear data -->
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Text styleClass="text" text="Clear All Data"/>
                                        <Text styleClass="muted-text"
                                              text="Permanently delete all journal entries, photos, and albums. This cannot be undone."/>
                                    </children>
                                </VBox>
                                <Button fx:id="clearDataButton" mnemonicParsing="false"
                                        stylesheets="@../stylesheets/buttons.css"
                                        text="Clear Data"
                                        style="-fx-background-color: #7f1d1d;
                                               -fx-text-fill: white;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 13px;
                                               -fx-padding: 10 17;">
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </VBox>

                <!-- ── DSA CONCEPTS USED ─────────────────── -->
                <VBox spacing="14.0"
                      style="-fx-background-color: #1e1e1e; -fx-background-radius: 12; -fx-padding: 20;">
                    <children>
                        <Text styleClass="text"
                              style="-fx-font-size: 18px; -fx-font-weight: bold;"
                              text="Data Structures &amp; Algorithms Used"/>
                        <Separator style="-fx-background-color: #333;"/>

                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Trees"
                                      style="-fx-min-width: 160px;"/>
                                <Text styleClass="text" wrappingWidth="480.0"
                                      text="Hierarchical album/folder organization (AlbumTree)"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Stacks"
                                      style="-fx-min-width: 160px;"/>
                                <Text styleClass="text" wrappingWidth="480.0"
                                      text="Undo / Redo functionality (AppStack)"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Queues"
                                      style="-fx-min-width: 160px;"/>
                                <Text styleClass="text" wrappingWidth="480.0"
                                      text="Memory recall processing and sequential task management (AppQueue)"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Arrays"
                                      style="-fx-min-width: 160px;"/>
                                <Text styleClass="text" wrappingWidth="480.0"
                                      text="Storing tags, photo paths, and entry lists (ArrayList)"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Merge Sort"
                                      style="-fx-min-width: 160px;"/>
                                <Text styleClass="text" wrappingWidth="480.0"
                                      text="Sorting journal entries by date and title (Sorter)"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Quick Sort"
                                      style="-fx-min-width: 160px;"/>
                                <Text styleClass="text" wrappingWidth="480.0"
                                      text="Sorting photos by date and name (Sorter)"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="Binary Search"
                                      style="-fx-min-width: 160px;"/>
                                <Text styleClass="text" wrappingWidth="480.0"
                                      text="Fast retrieval of entries and photos by date (BinarySearcher)"/>
                            </children>
                        </HBox>
                        <HBox spacing="12.0" alignment="TOP_LEFT">
                            <children>
                                <Text styleClass="muted-text" text="File Handling"
                                      style="-fx-min-width: 160px;"/>
                                <Text styleClass="text" wrappingWidth="480.0"
                                      text="Local persistence of entries, photos, and albums (StorageManager)"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
